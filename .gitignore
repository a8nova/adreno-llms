# Build artifacts
build/
build_tests/
*.o
*.a
*.so
*.dylib
compile_commands.json
CMakeCache.txt
CMakeFiles/

# Everything under any weights/ directory is fetched from HuggingFace via
# scripts/fetch_weights.sh — not committed to git. The directory itself is
# kept in tree via a .gitkeep marker so the path exists after clone.
**/weights/*
!**/weights/.gitkeep

# Per-model dev artifacts (regenerable, large)
.nnport/
.nnopt/
.nnport_venv/
.cache/
.deploy_manifest.json
layer_dumps/
layer_dumps_fixed/
layer_dumps_new/
**/reference/layers/
logs/
kernel_cache/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Local demo captures (kept private, never committed)
adreno-llms-demos/

# MMS-TTS language packs (~70 MB per zip, distributed via HuggingFace dataset)
**/packs/

# Uroman romanization tables, fetched on demand by scripts/fetch_uroman.sh
**/assets/uroman/

# Local reference-output dumps from prep_lang.py / cos_check.py
**/reference/reference/

# Local Claude Code config
**/.claude/

# espeak-ng phonemizer data for Kokoro — fetched per-language from HF via
# scripts/fetch_espeak_lang.sh (English base + add-on languages), not committed.
**/assets/espeak-ng-data/

# Kokoro voice packs — fetched from HF (54 voices) via scripts/fetch_voice.sh,
# not committed (the default af_heart is just one of them).
**/assets/voice_pack_*.bin

# Editor/agent backup files — never commit these
*.bak
*.megabak
*bak
*.orig
*.swp
*~

# NNPort snapshot / scratch trees — full per-model working copies (weights,
# builds, layer dumps, .nnport). Multi-GB and regenerable. lint_scripts.sh
# already skips these; keep them out of the tree entirely.
src/models/v2/
src/models/v3/

# Per-model benchmark scratch
**/.bench/

# Screen / demo captures — kept private, never committed (see also
# adreno-llms-demos/ above). None are referenced by any README.
*.mp4
*.mov

# Local-only build helpers with machine-specific absolute paths — never committed.
/build_all_for_*.sh
