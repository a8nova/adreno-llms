# scripts/remote_dir.env — shared source-of-truth.
# Sourced by both deploy_android.sh and run_android.sh so REMOTE_DIR +
# BINARY_NAME can't drift between the two. Override at invocation time:
#     REMOTE_DIR=/my/path ./scripts/deploy_android.sh
#     NNOPT_DTYPE=fp16    ./scripts/run_android.sh "hello"
REMOTE_DIR="${REMOTE_DIR:-/data/local/tmp/functiongemma_270m_it_inference}"
NNOPT_DTYPE="${NNOPT_DTYPE:-fp16}"
case "$NNOPT_DTYPE" in
    fp16) NNOPT_BIN_SUFFIX="_fp16" ;;
    fp32|"") NNOPT_BIN_SUFFIX="" ;;
    *)
        echo "ERROR: NNOPT_DTYPE must be fp32 or fp16 (got '$NNOPT_DTYPE')" >&2
        exit 1
        ;;
esac
BINARY_NAME="functiongemma_270m_it_inference${NNOPT_BIN_SUFFIX}"
export REMOTE_DIR NNOPT_DTYPE NNOPT_BIN_SUFFIX BINARY_NAME
